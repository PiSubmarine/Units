root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.{bat,cmd,ps1}]
end_of_line = crlf
indent_style = space
indent_size = 4

[*.{c,cc,cpp,cxx,h,hh,hpp,hxx,h++,inl,ipp,ixx,tpp}]
indent_style = tab
indent_size = 4
tab_width = 4
max_line_length = 120

[*.cmake]
indent_style = space
indent_size = 4
tab_width = 4
max_line_length = 120

[CMakeLists.txt]
indent_style = space
indent_size = 4
tab_width = 4
max_line_length = 120
